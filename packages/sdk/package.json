{
  "name": "@veridion/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript SDK for the Veridion API",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@veridion/shared": "workspace:*"
  },
  "devDependencies": {
    "@veridion/tsconfig": "workspace:*",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
