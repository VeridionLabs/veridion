{
  "name": "@veridion/report-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Audit report generation in multiple formats",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@veridion/logger": "workspace:*",
    "@veridion/shared": "workspace:*",
    "marked": "^12.0.0"
  },
  "devDependencies": {
    "@veridion/tsconfig": "workspace:*",
    "typescript": "^7.0.2",
    "vitest": "^1.6.0"
  }
}
