{
  "name": "@veridion/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, enums, constants, DTOs, and utilities for Veridion",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./enums": "./src/enums/index.ts",
    "./constants": "./src/constants/index.ts",
    "./utils": "./src/utils/index.ts",
    "./dtos": "./src/dtos/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@veridion/tsconfig": "workspace:*",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10"
  }
}
