{
  "name": "@veridion/ai-engine",
  "version": "0.1.0",
  "private": true,
  "description": "AI engine with provider abstraction for smart contract analysis",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./openai": "./src/providers/openai.ts",
    "./anthropic": "./src/providers/anthropic.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 0",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@veridion/logger": "workspace:*",
    "@veridion/shared": "workspace:*"
  },
  "devDependencies": {
    "@veridion/tsconfig": "workspace:*",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10"
  }
}
