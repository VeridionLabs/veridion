{
  "name": "@veridion/api",
  "version": "0.1.0",
  "private": true,
  "description": "Veridion API - NestJS backend",
  "scripts": {
    "dev": "node node_modules/@nestjs/cli/bin/nest.js start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bull-board/api": "^5.19.0",
    "@bull-board/express": "^5.19.0",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.9",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/swagger": "^7.3.1",
    "@nestjs/throttler": "^5.2.0",
    "@prisma/client": "^5.14.0",
    "@veridion/auth": "workspace:*",
    "@veridion/ai-engine": "workspace:*",
    "@veridion/database": "workspace:*",
    "bcryptjs": "^2.4.3",
    "@veridion/logger": "workspace:*",
    "@veridion/parser": "workspace:*",
    "@veridion/report-generator": "workspace:*",
    "@veridion/scanner-core": "workspace:*",
    "@veridion/scanner-types": "workspace:*",
    "@veridion/shared": "workspace:*",
    "bullmq": "^5.80.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-headerapikey": "^1.2.2",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/passport-jwt": "^4.0.1",
    "@veridion/eslint-config": "workspace:*",
    "@veridion/tsconfig": "workspace:*",
    "eslint": "^8.57.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
